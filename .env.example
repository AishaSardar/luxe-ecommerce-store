# ============================================================
# LUXE E-Commerce Store — Environment Variables
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env.local
# 2. Fill in your actual values
# 3. NEVER commit .env.local to GitHub
# 4. Add these variables in Vercel Dashboard → Project Settings → Environment Variables
# ============================================================

# App Info
VITE_APP_NAME=LUXE Store
VITE_APP_URL=https://luxe-store.vercel.app

# API Base URL (change per environment)
VITE_API_BASE_URL=https://api.luxe-store.com

# Payment (Stripe)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Analytics
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Feature Flags
VITE_ENABLE_NEWSLETTER=true
VITE_ENABLE_REVIEWS=true
